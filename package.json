{
  "name": "kurvenlineal",
  "version": "0.1.0",
  "description": "fit a bezier easing (quadratic or cubic) to an existing size scale — the curve owns the scale",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "easing",
    "bezier",
    "curve-fitting",
    "design-tokens",
    "type-scale",
    "spacing-scale"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
